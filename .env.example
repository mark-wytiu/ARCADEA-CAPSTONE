# Copy to `.env.local` and adjust values. CRA only exposes variables prefixed with REACT_APP_.

# Backend API (no trailing slash)
REACT_APP_API_BASE_URL=http://localhost:5050

# Steam library import (https://steamcommunity.com/dev/apikey)
REACT_APP_STEAM_API_KEY=

# Optional: prefix URL for browser CORS when calling Steam API (e.g. a dev proxy)
REACT_APP_CORS_PROXY=

# Optional: image CDN template — see src/utils/imageSources.js ({encodedUrl}, {width})
# REACT_APP_IMAGE_CDN_TEMPLATE=https://images.weserv.nl/?url={encodedUrl}&w={width}&output=webp&n=-1

# Optional: probe .webp/.avif variants when resolving game images
# REACT_APP_IMAGE_MODERN_FORMATS=true

# Log Web Vitals to the console in production builds (always on in development)
# REACT_APP_LOG_WEB_VITALS=true
